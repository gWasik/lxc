Host git git.moscow.alfaintra.net
  HostName git.moscow.alfaintra.net
  IdentitiesOnly yes
  PubkeyAcceptedKeyTypes +ssh-rsa

Host alfa-vpn
    User vartamonov
    RequestTTY yes
    #ProxyCommand ssh corpdev$((1+$((RANDOM %% 3)))) nc localhost 2222
    ProxyCommand ssh corpdev1 nc localhost 2222

Host corpdev* corpint* corpmesosint* corplogint* corpmonitorint* corpmgr*
   User u_m15sm

Host abm* corp* ufrapp* !corpdev* !corpint* !corpmesosint* !corplogint* !corpmonitorint* !corpmgr*
   User u_m15sm
   RequestTTY yes
   ProxyCommand ssh alfa-vpn nc %h 22

Host vobipvpn
	User wlsadm
	RequestTTY yes

Host vobipdev
	User wlsadm
	RequestTTY yes
	ProxyCommand ssh alfa-vpn nc %h 22

Host skp-db6
	User webdeploy
	RequestTTY yes
	ProxyCommand ssh alfa-vpn nc %h 22

Host *
	User root
	Port 22
	StrictHostKeyChecking no

