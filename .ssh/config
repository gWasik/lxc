AddKeysToAgent yes
TCPKeepAlive yes
ServerAliveInterval 300
ServerAliveCountMax 3
IdentityFile ~/.ssh/id_rsa
#    IdentityFile c:/Users/wasik/.ssh/id_rsa
#    IdentityFile c:/Users/wasik/.ssh/id_pi_rsa

Host bastion bastion.lan b
    HostName bastion.wasik.ru
    User awasik
	Port 11111

Host bastion.wasik.ru y.wasik.ru w.wasik.ru ssh.wasik.ru
    User awasik
	Port 11111

Host homebastion
    HostName homebastion.wasik.ru
    User root
	Port 11111

Host 192.168.254.2 192.168.254.22 ds awasikds 192.168.245.22 awasikds
	User admin

Host 192.168.*.254 deda* lena* onega* deti* dacha* papa* svobodagate* gate* testgate* lucy* anesv* nesv* luzer* work* mochilov* svoboda* ow* kuga* mudi* roma* ira*
    CanonicalizeHostname yes
    CanonicalDomains lan
	HostName %h.lan
	Port 11111
	ProxyJump bastion,homebastion

Host node*
    CanonicalizeHostname yes
    CanonicalDomains wasik.ru
	HostName %h.wasik.ru
	Port 11111
	ProxyJump bastion

Host *.wasik.ru
	ProxyJump bastion

